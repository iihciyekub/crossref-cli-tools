#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const {
    decodeHtmlEntities,
    fetchWithRetry,
    readStdin,
    readVersion,
    trim,
} = require("./lib/node-cli-utils");

const BASE_URL = "https://apps.crossref.org/SimpleTextQuery";
const USER_AGENT = "crossref-stq-node/0.1.0";
const VERSION = readVersion(__dirname);

function usage() {
    return `Usage:
  crossref-stq [options] [file]
  crossref-stq --text "citation text"
  cat refs.txt | crossref-stq --stdin

Options:
  --stdin         Read reference text from stdin
  --text TEXT     Read reference text from a CLI argument
  --include-pm    Ask Crossref to include PubMed IDs
  --multi-hit     Ask Crossref to return all DOI candidates
  --verbose       Print reference details instead of DOI-only output
  --json          Print JSON
  --version       Show version
  -h, --help      Show this help`;
}

function fail(message) {
    console.error(message);
    process.exit(1);
}

function parseArgs(argv) {
    const options = {
        useStdin: false,
        textArg: "",
        includePm: false,
        multiHit: false,
        verbose: false,
        json: false,
        fileArg: "",
    };

    for (let index = 0; index < argv.length; index += 1) {
        const current = argv[index];
        switch (current) {
            case "--stdin":
                options.useStdin = true;
                break;
            case "--text":
                index += 1;
                options.textArg = argv[index] || "";
                if (!options.textArg) {
                    fail("--text requires a value");
                }
                break;
            case "--include-pm":
                options.includePm = true;
                break;
            case "--multi-hit":
                options.multiHit = true;
                break;
            case "--verbose":
                options.verbose = true;
                break;
            case "--json":
                options.json = true;
                break;
            case "--version":
                console.log(VERSION);
                process.exit(0);
                break;
            case "--help":
            case "-h":
                console.log(usage());
                process.exit(0);
                break;
            default:
                if (current.startsWith("-")) {
                    fail(`Unknown option: ${current}`);
                }
                if (options.fileArg) {
                    fail("Only one input file is supported");
                }
                options.fileArg = current;
                break;
        }
    }

    return options;
}

async function readInput(options) {
    if (options.textArg) {
        return options.textArg;
    }

    if (options.useStdin) {
        return readStdin();
    }

    if (options.fileArg) {
        return fs.promises.readFile(options.fileArg, "utf8");
    }

    if (!process.stdin.isTTY) {
        return readStdin();
    }

    fail("No input provided. Use a file, --text, or --stdin.");
}

function extractFormKey(html) {
    const match = String(html || "").match(/name="key"\s+value=\s*"([^"]*)"/i);
    return match ? match[1] : "";
}

function extractCookieHeader(headers) {
    const raw = typeof headers.getSetCookie === "function"
        ? headers.getSetCookie().join(", ")
        : headers.get("set-cookie") || "";

    const matches = raw.match(/[A-Za-z0-9_]+=[^;,]+/g) || [];
    return matches.join("; ");
}

function extractResultBlocks(html) {
    const blocks = [];
    const pattern = /<tr class="resultB"><td class="resultB" colspan="4"[^>]*>(.*?)<\/td><\/tr>/gis;
    for (const match of String(html || "").matchAll(pattern)) {
        blocks.push(match[1]);
    }
    return blocks;
}

function parseResultBlock(block) {
    const dois = [];
    for (const match of String(block || "").matchAll(/<a\b[^>]*href="(https:\/\/doi\.org\/[^"]+)"/gis)) {
        if (!dois.includes(match[1])) {
            dois.push(match[1]);
        }
    }

    const pmidMatch = String(block || "").match(/PMid:\s*([0-9]+)/i);
    const pmid = pmidMatch ? pmidMatch[1] : null;

    let text = String(block || "")
        .replace(/<br\s*\/?>/gi, "\n")
        .replace(/<a\b[^>]*>.*?<\/a>/gis, "")
        .replace(/<[^>]+>/g, "")
        .replace(/\r/g, "");
    text = decodeHtmlEntities(text);

    const lines = text
        .split(/\n+/)
        .map((item) => item.trim().replace(/\s+/g, " "))
        .filter(Boolean);

    let reference = "";
    for (const line of lines) {
        if (/doi\.org\//i.test(line)) {
            continue;
        }
        if (/^PMid:/i.test(line)) {
            continue;
        }
        reference = line;
        break;
    }

    return {
        reference,
        dois,
        pmid,
    };
}

async function main() {
    const options = parseArgs(process.argv.slice(2));
    let inputText = trim(await readInput(options));
    if (!inputText) {
        fail("Input is empty.");
    }

    const pageResponse = await fetchWithRetry(BASE_URL, {
        headers: {
            "user-agent": USER_AGENT,
        },
    });
    const pageHtml = await pageResponse.text();
    const formKey = extractFormKey(pageHtml);
    if (!formKey) {
        fail("Failed to extract hidden form key.");
    }

    const cookieHeader = extractCookieHeader(pageResponse.headers);
    const params = new URLSearchParams();
    params.set("command", "Submit");
    params.set("key", formKey);
    params.set("freetext", inputText);
    if (options.includePm) {
        params.set("includePM", "on");
    }
    if (options.multiHit) {
        params.set("multihit", "on");
    }

    const resultResponse = await fetchWithRetry(BASE_URL, {
        method: "POST",
        headers: {
            "user-agent": USER_AGENT,
            "content-type": "application/x-www-form-urlencoded",
            ...(cookieHeader ? { cookie: cookieHeader } : {}),
        },
        body: params.toString(),
    });
    const resultHtml = await resultResponse.text();
    const rows = extractResultBlocks(resultHtml).map(parseResultBlock);

    if (options.json) {
        console.log(JSON.stringify(rows, null, 2));
        return;
    }

    if (rows.length === 0) {
        console.log("No matches returned.");
        return;
    }

    if (options.verbose) {
        rows.forEach((row, index) => {
            const reference = row.reference || "(empty reference)";
            process.stdout.write(`[${index + 1}] ${reference}\n`);
            if (row.dois.length > 0) {
                row.dois.forEach((doi) => {
                    process.stdout.write(`  DOI: ${doi}\n`);
                });
            } else {
                process.stdout.write("  DOI: (none)\n");
            }
            if (row.pmid) {
                process.stdout.write(`  PMID: ${row.pmid}\n`);
            }
            if (index < rows.length - 1) {
                process.stdout.write("\n");
            }
        });
        return;
    }

    for (const row of rows) {
        for (const doi of row.dois) {
            process.stdout.write(`${doi}\n`);
        }
    }
}

main().catch((error) => {
    console.error(error.message);
    process.exit(1);
});
