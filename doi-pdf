#!/usr/bin/env node

const fs = require("fs");
const os = require("os");
const path = require("path");
const { decodeHtmlEntities, fetchWithRetry } = require("./lib/node-cli-utils");

const VERSION = readVersion();
const DOI_REGEX = /10\.\d{4,9}\/[-._;()/:A-Z0-9]+/i;
const DEFAULT_MAX_CONCURRENCY = 3;
const DEFAULT_OUTPUT_DIR = "papers";
const DEFAULT_CONFIG_PATH = path.join(os.homedir(), ".config", "crossref-cli", "doi-pdf.json");

function readVersion() {
    try {
        const packagePath = path.join(__dirname, "package.json");
        return JSON.parse(fs.readFileSync(packagePath, "utf8")).version || "0.0.0";
    } catch {
        return "0.0.0";
    }
}

function usage() {
    return `doi-pdf ${VERSION}

Usage:
  ./doi-pdf [options] <doi> [doi ...]
  printf '%s\\n' <doi> | ./doi-pdf [options]
  ./doi-pdf --items items.json
  cat items.jsonl | ./doi-pdf --stdin-json

Input:
  DOI values may also be DOI URLs such as https://doi.org/10.1000/xyz123

Options:
  --source URL        Download source base URL or URL template.
                      If the value contains {doi} or {doi_encoded},
                      the placeholder will be replaced directly.
                      The configured source is tried first, then
                      doi.org resolution is used as a fallback.
  --config FILE       Read configuration from JSON file.
  --items FILE        Read Zotero-style item JSON from FILE.
                      Accepts a JSON object, a JSON array, or JSON Lines.
  --stdin-json        Parse stdin as Zotero-style JSON / JSON Lines.
  --out DIR           Save PDFs into DIR. Default: ./papers
  --concurrency N     Parallel downloads. Default: 3, max: 3
  --init-config       Create the JSON config file and exit.
                      Requires an explicit --source value.
  --force             Overwrite config file when used with --init-config.
  --print-config      Print the resolved configuration as JSON and exit.
  --help              Show this help text.
  --version           Show version.

Configuration priority:
  1. CLI options
  2. Environment variables
  3. JSON config file
  4. Built-in defaults

Environment variables:
  DOI2PDF_SOURCE_URL
  DOI2PDF_BASE_URL    Legacy alias for DOI2PDF_SOURCE_URL
  DOI2PDF_OUTPUT_DIR
  DOI2PDF_MAX_CONCURRENCY
  DOI2PDF_CONFIG

Config file example:
  {
    "source": "https://example.org/{doi}",
    "outputDir": "papers",
    "maxConcurrency": 2
  }
`;
}

function fail(message) {
    console.error(message);
    process.exit(1);
}

function parseArgs(argv) {
    const options = {
        dois: [],
        source: null,
        configPath: null,
        itemsPath: null,
        outputDir: null,
        concurrency: null,
        stdinJson: false,
        initConfig: false,
        force: false,
        printConfig: false,
        help: false,
        version: false,
    };

    for (let index = 0; index < argv.length; index += 1) {
        const current = argv[index];

        if (current === "--") {
            options.dois.push(...argv.slice(index + 1));
            break;
        }

        if (current === "--help" || current === "-h") {
            options.help = true;
            continue;
        }

        if (current === "--version") {
            options.version = true;
            continue;
        }

        if (current === "--print-config") {
            options.printConfig = true;
            continue;
        }

        if (current === "--init-config") {
            options.initConfig = true;
            continue;
        }

        if (current === "--force") {
            options.force = true;
            continue;
        }

        if (current === "--source") {
            index += 1;
            options.source = requireValue(argv[index], "--source");
            continue;
        }

        if (current === "--config") {
            index += 1;
            options.configPath = requireValue(argv[index], "--config");
            continue;
        }

        if (current === "--items") {
            index += 1;
            options.itemsPath = requireValue(argv[index], "--items");
            continue;
        }

        if (current === "--out") {
            index += 1;
            options.outputDir = requireValue(argv[index], "--out");
            continue;
        }

        if (current === "--concurrency") {
            index += 1;
            options.concurrency = parsePositiveInteger(requireValue(argv[index], "--concurrency"), "--concurrency");
            continue;
        }

        if (current === "--stdin-json") {
            options.stdinJson = true;
            continue;
        }

        if (current.startsWith("--")) {
            fail(`Unknown option: ${current}`);
        }

        options.dois.push(current);
    }

    return options;
}

function requireValue(value, flag) {
    if (!value) {
        fail(`Missing value for ${flag}`);
    }

    return value;
}

function parsePositiveInteger(value, label) {
    const parsed = Number.parseInt(String(value), 10);
    if (!Number.isFinite(parsed) || parsed <= 0) {
        fail(`Invalid value for ${label}: ${value}`);
    }

    return parsed;
}

async function loadConfig(configPath, options = {}) {
    const allowMissing = Boolean(options.allowMissing);
    const resolvedPath = path.resolve(configPath || process.env.DOI2PDF_CONFIG || DEFAULT_CONFIG_PATH);
    const explicit = Boolean(configPath || process.env.DOI2PDF_CONFIG);

    try {
        const raw = await fs.promises.readFile(resolvedPath, "utf8");
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
            throw new Error("Config must be a JSON object");
        }

        return { config: parsed, path: resolvedPath };
    } catch (error) {
        if (error.code === "ENOENT" && (!explicit || allowMissing)) {
            return { config: {}, path: resolvedPath };
        }

        throw new Error(`Failed to read config ${resolvedPath}: ${error.message}`);
    }
}

function resolveSettings(cliOptions, fileConfig) {
    const rawSource =
        cliOptions.source ||
        process.env.DOI2PDF_SOURCE_URL ||
        process.env.DOI2PDF_BASE_URL ||
        fileConfig.source ||
        null;
    const rawOutputDir = cliOptions.outputDir || process.env.DOI2PDF_OUTPUT_DIR || fileConfig.outputDir || DEFAULT_OUTPUT_DIR;
    const rawConcurrency =
        cliOptions.concurrency ||
        parseOptionalPositiveInteger(process.env.DOI2PDF_MAX_CONCURRENCY) ||
        parseOptionalPositiveInteger(fileConfig.maxConcurrency) ||
        DEFAULT_MAX_CONCURRENCY;

    return {
        source: normalizeSource(rawSource),
        outputDir: path.resolve(process.cwd(), rawOutputDir),
        maxConcurrency: Math.min(rawConcurrency, DEFAULT_MAX_CONCURRENCY),
    };
}

async function initConfigFile(cliOptions, configPath, settings) {
    if (!cliOptions.source) {
        throw new Error("--init-config requires an explicit --source value.");
    }

    const payload = {
        source: normalizeSource(cliOptions.source),
        outputDir: path.relative(process.cwd(), settings.outputDir) || ".",
        maxConcurrency: settings.maxConcurrency,
    };

    const parentDir = path.dirname(configPath);
    await fs.promises.mkdir(parentDir, { recursive: true });

    if (!cliOptions.force) {
        try {
            await fs.promises.access(configPath, fs.constants.F_OK);
            throw new Error(`Config already exists: ${configPath}. Re-run with --force to overwrite.`);
        } catch (error) {
            if (error.code !== "ENOENT") {
                throw error;
            }
        }
    }

    await fs.promises.writeFile(configPath, `${JSON.stringify(payload, null, 2)}\n`, "utf8");
    console.error(`Wrote config to ${configPath}`);
}

function parseOptionalPositiveInteger(value) {
    if (value === undefined || value === null || value === "") {
        return null;
    }

    const parsed = Number.parseInt(String(value), 10);
    if (!Number.isFinite(parsed) || parsed <= 0) {
        return null;
    }

    return parsed;
}

function normalizeSource(value) {
    if (!value) {
        return null;
    }

    const trimmed = String(value).trim();
    if (trimmed.length === 0) {
        return null;
    }

    if (trimmed.includes("{doi}") || trimmed.includes("{doi_encoded}")) {
        return trimmed;
    }

    return trimmed.endsWith("/") ? trimmed : `${trimmed}/`;
}

function extractDoiFromText(text) {
    if (!text) {
        return null;
    }

    const decoded = safeDecode(text);
    const match = decoded.match(DOI_REGEX);
    return match ? trimTrailingPunctuation(match[0]) : null;
}

function safeDecode(value) {
    try {
        return decodeURIComponent(value);
    } catch {
        return value;
    }
}

function trimTrailingPunctuation(value) {
    return value.replace(/[)\].,;]+$/g, "");
}

function filenameForDoi(doi) {
    return `${doi.replaceAll("/", "_")}.pdf`;
}

function normalizeWhitespace(value) {
    return String(value || "").replace(/\s+/g, " ").trim();
}

function cleanDoiCandidate(input) {
    const decoded = normalizeWhitespace(safeDecode(String(input || "")));
    if (!decoded) {
        return "";
    }

    const trimmed = decoded
        .replace(/^(?:doi\s*:|urn\s*:doi\s*:)\s*/i, "")
        .replace(/^https?:\/\/(?:dx\.)?doi\.org\//i, "")
        .replace(/^https?:\/\/[^/\s]+\/(?:article|doi|content\/pdf)\//i, "");

    return trimTrailingPunctuation(trimmed);
}

function getFieldCaseInsensitive(item, name) {
    if (!item || typeof item !== "object" || Array.isArray(item)) {
        return null;
    }

    const lowered = String(name).toLowerCase();
    for (const [key, value] of Object.entries(item)) {
        if (String(key).toLowerCase() === lowered) {
            return value;
        }
    }

    return null;
}

function getDoiFromExtraField(extra) {
    const text = typeof extra === "string"
        ? extra
        : Array.isArray(extra)
            ? extra.join("\n")
            : "";
    const match = text.match(/^DOI:\s*(.+)$/im);
    return match ? match[1].trim() : null;
}

function getDoiFromUrlField(url) {
    const raw = typeof url === "string" ? url.trim() : "";
    if (!raw || !/\bdoi\.org\b/i.test(raw)) {
        return null;
    }

    try {
        return decodeURIComponent(new URL(raw).pathname).replace(/^\/+/, "");
    } catch {
        return null;
    }
}

function extractDoiFromItem(item) {
    if (!item || typeof item !== "object" || Array.isArray(item)) {
        return null;
    }

    const directDoi =
        getFieldCaseInsensitive(item, "DOI") ||
        getFieldCaseInsensitive(item, "doi");
    const extraDoi = getDoiFromExtraField(getFieldCaseInsensitive(item, "extra"));
    const urlDoi = getDoiFromUrlField(getFieldCaseInsensitive(item, "url"));

    return normalizeDoi(directDoi) || normalizeDoi(extraDoi) || normalizeDoi(urlDoi);
}

function normalizeDoi(input) {
    const cleaned = cleanDoiCandidate(input);
    const extracted = extractDoiFromText(cleaned) || extractDoiFromText(input);
    const doi = extracted || cleaned;
    return DOI_REGEX.test(doi) ? doi.toLowerCase() : null;
}

function buildPageUrl(source, doi) {
    if (source.includes("{doi}") || source.includes("{doi_encoded}")) {
        return source
            .replaceAll("{doi_encoded}", encodeURIComponent(doi))
            .replaceAll("{doi}", doi);
    }

    return `${source}${doi.replace(/^\/+/, "")}`;
}

function looksLikePdf(buffer) {
    return buffer.length >= 4 && buffer.subarray(0, 4).toString("ascii") === "%PDF";
}

function looksLikeHtml(buffer) {
    if (!buffer || buffer.length === 0) {
        return false;
    }

    const head = buffer.subarray(0, Math.min(buffer.length, 512)).toString("utf8").trimStart().toLowerCase();
    return head.startsWith("<!doctype html") || head.startsWith("<html") || head.startsWith("<head") || head.startsWith("<body");
}

function formatErrorMessage(error) {
    if (!error) {
        return "Unknown error";
    }

    const primaryMessage = typeof error.message === "string" && error.message.trim().length > 0
        ? error.message.trim()
        : String(error);
    const parts = [primaryMessage];
    const seen = new Set(parts);
    let current = error.cause;
    let depth = 0;

    while (current && depth < 5) {
        const details = [];
        const causeMessage = typeof current.message === "string" ? current.message.trim() : "";
        if (causeMessage && !seen.has(causeMessage)) {
            details.push(causeMessage);
            seen.add(causeMessage);
        }

        for (const extra of [current.code, current.hostname]) {
            if (typeof extra !== "string" || extra.trim().length === 0) {
                continue;
            }

            const normalized = extra.trim();
            if (seen.has(normalized) || (causeMessage && causeMessage.includes(normalized))) {
                continue;
            }

            details.push(normalized);
            seen.add(normalized);
        }

        if (details.length > 0) {
            parts.push(details.join(" "));
        }

        current = current.cause;
        depth += 1;
    }

    return parts.join(": ");
}

async function fetchText(url) {
    let response;
    try {
        response = await fetchWithRetry(url, {
            redirect: "follow",
            headers: {
                "user-agent": "Mozilla/5.0 doi-pdf Downloader",
                accept: "text/html,application/pdf;q=0.9,*/*;q=0.8",
            },
        });
    } catch (error) {
        throw new Error(`Failed to fetch page ${url}`, { cause: error });
    }

    const contentType = response.headers.get("content-type") || "";
    if (contentType.toLowerCase().includes("application/pdf")) {
        return {
            text: "",
            finalUrl: response.url,
            contentType,
        };
    }

    try {
        return {
            text: await response.text(),
            finalUrl: response.url,
            contentType,
        };
    } catch (error) {
        throw new Error(`Failed to read response body from ${response.url}`, { cause: error });
    }
}

function resolveUrl(candidate, baseUrl) {
    try {
        return new URL(candidate, baseUrl).href;
    } catch {
        return null;
    }
}

function appendUniqueUrl(items, candidate, baseUrl) {
    const decoded = decodeHtmlEntities(candidate);
    const resolved = resolveUrl(decoded, baseUrl);
    if (resolved && !items.includes(resolved)) {
        items.push(resolved);
    }
}

function hostMatches(url, pattern) {
    try {
        return pattern.test(new URL(url).hostname);
    } catch {
        return false;
    }
}

function extractCanonicalDoiFromHandleResponse(payload) {
    if (!payload || typeof payload !== "object") {
        return null;
    }

    const directHandle = typeof payload.handle === "string" ? normalizeDoi(payload.handle) : null;
    if (directHandle) {
        return directHandle;
    }

    const values = Array.isArray(payload.values) ? payload.values : [];
    for (const entry of values) {
        const candidate = normalizeDoi(entry?.data?.value);
        if (candidate) {
            return candidate;
        }
    }

    return null;
}

async function fetchJson(url) {
    let response;
    try {
        response = await fetchWithRetry(url, {
            redirect: "follow",
            headers: {
                "user-agent": "Mozilla/5.0 doi-pdf Downloader",
                accept: "application/json,text/plain;q=0.9,*/*;q=0.8",
            },
        });
    } catch (error) {
        throw new Error(`Failed to fetch JSON ${url}`, { cause: error });
    }

    try {
        return await response.json();
    } catch (error) {
        throw new Error(`Failed to parse JSON from ${response.url}`, { cause: error });
    }
}

async function resolveCanonicalDoi(doi) {
    const normalized = normalizeDoi(doi);
    if (!normalized) {
        return null;
    }

    try {
        const payload = await fetchJson(`https://doi.org/api/handles/${encodeURIComponent(normalized)}`);
        return extractCanonicalDoiFromHandleResponse(payload) || normalized;
    } catch {
        return normalized;
    }
}

function deriveSpringerPdfUrls(baseUrl, expectedDoi, html) {
    const doi = expectedDoi || extractDoiFromText(baseUrl) || extractDoiFromText(html);
    if (!doi || !hostMatches(baseUrl, /(^|\.)link\.springer\.com$/i)) {
        return [];
    }

    return [
        `https://link.springer.com/content/pdf/${doi}.pdf`,
        `https://link.springer.com/content/pdf/${doi}.pdf?download=1`,
    ];
}

function extractCandidatePdfUrls(html, baseUrl, options = {}) {
    const candidates = [];
    const metaPatterns = [
        /<meta[^>]+name=["']citation_pdf_url["'][^>]+content=["']([^"']+)["']/ig,
        /<meta[^>]+content=["']([^"']+)["'][^>]+name=["']citation_pdf_url["']/ig,
        /<link[^>]+type=["']application\/pdf["'][^>]+href=["']([^"']+)["']/ig,
        /<link[^>]+href=["']([^"']+)["'][^>]+type=["']application\/pdf["']/ig,
        /(?:data-pdf-url|pdfUrl|downloadPdfUrl)["'\s:=]+([^"'\\s>]+(?:\.pdf|\/pdf|download)[^"'\s>]*)/ig,
    ];

    for (const pattern of metaPatterns) {
        for (const match of html.matchAll(pattern)) {
            appendUniqueUrl(candidates, match[1], baseUrl);
        }
    }

    for (const match of html.matchAll(/<(a|iframe|embed|object)[^>]+(?:href|src|data)=["']([^"']+)["'][^>]*>/ig)) {
        const raw = decodeHtmlEntities(match[2]);
        const lower = raw.toLowerCase();
        const looksPdf = lower.includes(".pdf") || lower.includes("/pdf") || lower.includes("download");
        if (!looksPdf) {
            continue;
        }

        appendUniqueUrl(candidates, raw, baseUrl);
    }

    for (const candidate of deriveSpringerPdfUrls(baseUrl, options.expectedDoi, html)) {
        appendUniqueUrl(candidates, candidate, baseUrl);
    }

    return candidates;
}

function detectAccessIssue(text, url) {
    const haystack = `${url}\n${text}`.toLowerCase();
    const markers = [
        "buy article",
        "institutional access",
        "access through your institution",
        "access provided by",
        "you do not have access",
        "purchase this article",
        "subscribe to this journal",
        "subscription required",
        "log in via an institution",
        "access options",
        "cookies_not_supported",
        'name="access" content="no"',
    ];

    if (markers.some((marker) => haystack.includes(marker))) {
        return "Publisher page does not expose a downloadable PDF for this session";
    }

    return null;
}

async function findPdfUrl(pageUrl, expectedDoi) {
    const page = await fetchText(pageUrl);
    if (page.contentType.toLowerCase().includes("application/pdf")) {
        return { pdfUrl: page.finalUrl, doi: expectedDoi || extractDoiFromText(page.finalUrl) };
    }

    const candidates = extractCandidatePdfUrls(page.text, page.finalUrl, { expectedDoi });
    if (candidates.length === 0) {
        const accessIssue = detectAccessIssue(page.text, page.finalUrl);
        throw new Error(accessIssue || `No PDF link found on ${page.finalUrl}`);
    }

    const doi = expectedDoi || extractDoiFromText(page.finalUrl) || extractDoiFromText(pageUrl) || extractDoiFromText(page.text);
    return { pdfUrl: candidates[0], doi };
}

function collectPageUrls(settings, doi) {
    const candidates = [];
    if (settings.source) {
        candidates.push(buildPageUrl(settings.source, doi));
    }
    candidates.push(`https://doi.org/${encodeURIComponent(doi)}`);
    return [...new Set(candidates)];
}

async function findPdfUrlWithFallback(settings, doi) {
    const errors = [];

    for (const pageUrl of collectPageUrls(settings, doi)) {
        try {
            return await findPdfUrl(pageUrl, doi);
        } catch (error) {
            errors.push({ pageUrl, error });
        }
    }

    const primary = errors[0];
    if (!primary) {
        throw new Error(`Unable to resolve a PDF URL for ${doi}`);
    }

    const details = errors
        .slice(1)
        .map(({ pageUrl, error }) => `${pageUrl} -> ${formatErrorMessage(error)}`)
        .join("; ");
    if (!details) {
        throw primary.error;
    }

    throw new Error(`${formatErrorMessage(primary.error)}; fallback attempts: ${details}`);
}

async function downloadFile(fileUrl, outputPath, options = {}) {
    const visited = options.visited || new Set();
    const normalizedUrl = String(fileUrl || "");

    if (visited.has(normalizedUrl)) {
        throw new Error(`Redirect loop while resolving PDF: ${normalizedUrl}`);
    }
    visited.add(normalizedUrl);

    let response;
    try {
        response = await fetchWithRetry(fileUrl, {
            redirect: "follow",
            headers: {
                "user-agent": "Mozilla/5.0 doi-pdf Downloader",
                accept: "application/pdf,*/*;q=0.8",
            },
        });
    } catch (error) {
        throw new Error(`Failed to fetch PDF ${fileUrl}`, { cause: error });
    }

    let buffer;
    try {
        const arrayBuffer = await response.arrayBuffer();
        buffer = Buffer.from(arrayBuffer);
    } catch (error) {
        throw new Error(`Failed to read PDF response from ${response.url}`, { cause: error });
    }

    if (looksLikePdf(buffer)) {
        await fs.promises.writeFile(outputPath, buffer);
        return outputPath;
    }

    const contentType = (response.headers.get("content-type") || "").toLowerCase();
    if (contentType.includes("text/html") || looksLikeHtml(buffer)) {
        const html = buffer.toString("utf8");
        const nestedCandidates = extractCandidatePdfUrls(html, response.url, { expectedDoi: options.expectedDoi });
        const nextCandidate = nestedCandidates.find((candidate) => !visited.has(candidate));
        if (nextCandidate) {
            return downloadFile(nextCandidate, outputPath, {
                ...options,
                visited,
            });
        }

        const accessIssue = detectAccessIssue(html, response.url);
        throw new Error(accessIssue || `Response is HTML, not a PDF (${response.url})`);
    }

    throw new Error(`Response is not a PDF (${contentType || "unknown content-type"})`);
}

async function downloadFromDoi(input, settings) {
    const normalizedInput = normalizeDoi(input);
    const doi = await resolveCanonicalDoi(normalizedInput);
    if (!doi) {
        throw new Error("Invalid DOI");
    }

    const { pdfUrl, doi: resolvedDoi = doi } = await findPdfUrlWithFallback(settings, doi);
    const outputPath = path.join(settings.outputDir, filenameForDoi(resolvedDoi));
    await downloadFile(pdfUrl, outputPath, { expectedDoi: resolvedDoi });
    return { doi: resolvedDoi, pdfUrl, outputPath };
}

async function runQueue(items, concurrency, worker) {
    const results = new Array(items.length);
    let nextIndex = 0;

    async function consume() {
        while (true) {
            const currentIndex = nextIndex;
            nextIndex += 1;
            if (currentIndex >= items.length) {
                return;
            }

            try {
                results[currentIndex] = { ok: true, value: await worker(items[currentIndex], currentIndex) };
            } catch (error) {
                results[currentIndex] = { ok: false, error };
            }
        }
    }

    const workers = Array.from({ length: Math.min(concurrency, items.length) }, () => consume());
    await Promise.all(workers);
    return results;
}

async function readStdin() {
    if (process.stdin.isTTY) {
        return "";
    }

    return new Promise((resolve, reject) => {
        let data = "";
        process.stdin.setEncoding("utf8");
        process.stdin.on("data", (chunk) => {
            data += chunk;
        });
        process.stdin.on("end", () => resolve(data));
        process.stdin.on("error", reject);
    });
}

function gatherDoiInputs(argvDois, stdinText) {
    const stdinDois = stdinText
        .split(/\r?\n|[\s,]+/g)
        .map((item) => item.trim())
        .filter(Boolean);

    return [...argvDois, ...stdinDois];
}

function tryParseJson(value) {
    try {
        return JSON.parse(value);
    } catch {
        return null;
    }
}

function parseJsonLines(value) {
    const items = [];
    for (const line of String(value || "").split(/\r?\n/)) {
        const trimmed = line.trim();
        if (!trimmed) {
            continue;
        }

        const parsed = tryParseJson(trimmed);
        if (parsed !== null) {
            items.push(parsed);
        }
    }
    return items;
}

function normalizeItemList(value) {
    if (Array.isArray(value)) {
        return value;
    }

    if (value && typeof value === "object") {
        return [value];
    }

    return [];
}

function parseItemsInput(text, label) {
    const trimmed = String(text || "").trim();
    if (!trimmed) {
        return [];
    }

    const asJson = tryParseJson(trimmed);
    if (asJson !== null) {
        return normalizeItemList(asJson);
    }

    const asJsonLines = parseJsonLines(trimmed);
    if (asJsonLines.length > 0) {
        return asJsonLines;
    }

    throw new Error(`Failed to parse item JSON from ${label}`);
}

async function readItemsFile(itemsPath) {
    if (!itemsPath) {
        return [];
    }

    const resolved = path.resolve(itemsPath);
    const raw = await fs.promises.readFile(resolved, "utf8");
    return parseItemsInput(raw, resolved);
}

function gatherItemInputs(itemObjects) {
    return itemObjects
        .map((item) => extractDoiFromItem(item))
        .filter(Boolean);
}

function unique(items) {
    return [...new Set(items)];
}

function printResolvedConfig(settings, configPath) {
    console.log(
        JSON.stringify(
            {
                source: settings.source,
                outputDir: settings.outputDir,
                maxConcurrency: settings.maxConcurrency,
                configPath,
            },
            null,
            2,
        ),
    );
}

async function main() {
    const cliOptions = parseArgs(process.argv.slice(2));

    if (cliOptions.help) {
        console.log(usage());
        return;
    }

    if (cliOptions.version) {
        console.log(VERSION);
        return;
    }

    const { config, path: configPath } = await loadConfig(cliOptions.configPath, {
        allowMissing: cliOptions.initConfig,
    });
    const settings = resolveSettings(cliOptions, config);

    if (cliOptions.initConfig) {
        await initConfigFile(cliOptions, configPath, settings);
        return;
    }

    if (cliOptions.printConfig) {
        printResolvedConfig(settings, configPath);
        return;
    }

    if (!settings.source) {
        fail("No download source configured. Use --source, DOI2PDF_SOURCE_URL, DOI2PDF_BASE_URL, or a JSON config file.");
    }

    const stdinText = await readStdin();
    const fileItems = await readItemsFile(cliOptions.itemsPath);
    const stdinItems = cliOptions.stdinJson ? parseItemsInput(stdinText, "stdin") : [];
    const doiInputs = unique([
        ...cliOptions.dois,
        ...gatherItemInputs(fileItems),
        ...gatherItemInputs(stdinItems),
        ...(cliOptions.stdinJson ? [] : gatherDoiInputs([], stdinText)),
    ]);

    if (doiInputs.length === 0) {
        fail("Usage: ./doi-pdf [options] <doi> [doi ...]");
    }

    await fs.promises.mkdir(settings.outputDir, { recursive: true });

    const queueResults = await runQueue(doiInputs, settings.maxConcurrency, async (doiInput) => {
        const result = await downloadFromDoi(doiInput, settings);
        console.error(`Downloaded ${result.doi} -> ${result.outputPath}`);
        return result.doi;
    });

    const successDois = [];
    queueResults.forEach((result, index) => {
        if (result?.ok) {
            successDois.push(result.value);
            return;
        }

        const rawInput = doiInputs[index];
        const message = formatErrorMessage(result?.error);
        console.error(`Skipped ${rawInput}: ${message}`);
    });

    console.log(JSON.stringify(successDois, null, 2));
}

main().catch((error) => {
    console.error(error.message);
    process.exit(1);
});
