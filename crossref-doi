#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const {
    fetchWithRetry,
    formatStyleSuggestions,
    readStdin,
    readVersion,
    sanitizeFilename,
    splitNonEmptyLines,
    strictUrlEncode,
    trim,
} = require("./lib/node-cli-utils");

const VERSION = readVersion(__dirname);
const USER_AGENT = "crossref-doi-node/0.1.0";
const DOI_BASE_URL = "https://doi.org";
const CROSSREF_API_BASE_URL = "https://api.crossref.org";

function usage() {
    return `Usage:
  crossref-doi [options] DOI...
  crossref-doi --doi DOI --doi DOI --format text --style apa
  printf '%s\\n' DOI DOI | crossref-doi
  crossref-doi --list-styles

Options:
  --doi DOI        DOI to retrieve, can be repeated
  --format NAME    text | bibtex | ris | csljson | json | unixref | unixsd
                   Default: text
  --style NAME     CSL style for --format text. Default: apa
  --locale NAME    Locale for --format text. Default: en-US
  --out DIR        Save each DOI result as a separate file in DIR
  --search-style K Search supported CSL style names by keyword
  --show-styles N  Show the first N CSL style names
  --list-styles    Print supported CSL style names from Crossref
  --version        Show version
  -h, --help       Show this help`;
}

function fail(message) {
    console.error(message);
    process.exit(1);
}

function fileExtensionForFormat(format) {
    switch (format) {
        case "text":
            return "txt";
        case "bibtex":
            return "bib";
        case "ris":
            return "ris";
        case "csljson":
            return "csl.json";
        case "json":
            return "json";
        case "unixref":
            return "unixref.xml";
        case "unixsd":
            return "unixsd.xml";
        default:
            return "out";
    }
}

function parseArgs(argv) {
    const options = {
        dois: [],
        format: "text",
        style: "apa",
        locale: "en-US",
        outDir: "",
        listStyles: false,
        searchStyle: "",
        showStyles: "",
    };

    for (let index = 0; index < argv.length; index += 1) {
        const current = argv[index];
        switch (current) {
            case "--doi":
                index += 1;
                if (!argv[index]) {
                    fail("--doi requires a value");
                }
                options.dois.push(argv[index]);
                break;
            case "--format":
                index += 1;
                options.format = argv[index] || "";
                if (!options.format) {
                    fail("--format requires a value");
                }
                break;
            case "--style":
                index += 1;
                options.style = argv[index] || "";
                if (!options.style) {
                    fail("--style requires a value");
                }
                break;
            case "--locale":
                index += 1;
                options.locale = argv[index] || "";
                if (!options.locale) {
                    fail("--locale requires a value");
                }
                break;
            case "--out":
                index += 1;
                options.outDir = argv[index] || "";
                if (!options.outDir) {
                    fail("--out requires a value");
                }
                break;
            case "--list-styles":
                options.listStyles = true;
                break;
            case "--search-style":
                index += 1;
                options.searchStyle = argv[index] || "";
                if (!options.searchStyle) {
                    fail("--search-style requires a value");
                }
                break;
            case "--show-styles":
                index += 1;
                options.showStyles = argv[index] || "";
                if (!options.showStyles) {
                    fail("--show-styles requires a value");
                }
                break;
            case "--version":
                console.log(VERSION);
                process.exit(0);
                break;
            case "--help":
            case "-h":
                console.log(usage());
                process.exit(0);
                break;
            default:
                if (current.startsWith("-")) {
                    fail(`Unknown option: ${current}`);
                }
                options.dois.push(current);
                break;
        }
    }

    return options;
}

async function listStylesFromApi() {
    const response = await fetchWithRetry(`${CROSSREF_API_BASE_URL}/v1/styles`, {
        headers: {
            "user-agent": USER_AGENT,
        },
    });
    const payload = await response.json();
    const items = payload?.message?.items;
    return Array.isArray(items) ? items : [];
}

async function ensureValidStyle(style) {
    const styles = await listStylesFromApi();
    const result = formatStyleSuggestions(style, styles);
    if (result.ok) {
        return;
    }

    console.error(`Unknown CSL style: ${style}`);
    if (result.suggestions.length > 0) {
        console.error("Did you mean:");
        result.suggestions.forEach((item) => {
            console.error(`  - ${item}`);
        });
    } else {
        console.error("Use --list-styles or --search-style to inspect available styles.");
    }
    process.exit(1);
}

async function maybeExplainStyleFailure(style, error) {
    try {
        await ensureValidStyle(style);
    } catch (styleError) {
        throw styleError;
    }

    throw error;
}

async function fetchOne(url, acceptHeader) {
    const headers = {
        "user-agent": USER_AGENT,
    };
    if (acceptHeader) {
        headers.accept = acceptHeader;
    }
    const response = await fetchWithRetry(url, { headers });
    return response.text();
}

function getRequestConfig(format, doi, style, locale) {
    const encoded = strictUrlEncode(doi);

    switch (format) {
        case "text":
            return {
                url: `${DOI_BASE_URL}/${encoded}`,
                acceptHeader: `text/x-bibliography; style=${style}; locale=${locale}`,
            };
        case "bibtex":
            return {
                url: `${DOI_BASE_URL}/${encoded}`,
                acceptHeader: "application/x-bibtex",
            };
        case "ris":
            return {
                url: `${DOI_BASE_URL}/${encoded}`,
                acceptHeader: "application/x-research-info-systems",
            };
        case "csljson":
            return {
                url: `${DOI_BASE_URL}/${encoded}`,
                acceptHeader: "application/vnd.citationstyles.csl+json",
            };
        case "unixref":
            return {
                url: `${DOI_BASE_URL}/${encoded}`,
                acceptHeader: "application/vnd.crossref.unixref+xml",
            };
        case "unixsd":
            return {
                url: `${DOI_BASE_URL}/${encoded}`,
                acceptHeader: "application/vnd.crossref.unixsd+xml",
            };
        case "json":
            return {
                url: `${CROSSREF_API_BASE_URL}/works/${encoded}`,
                acceptHeader: "",
            };
        default:
            fail(`Unsupported format: ${format}\nSupported formats: text, bibtex, ris, csljson, json, unixref, unixsd`);
    }
}

function validateShowStyles(value) {
    if (!/^[1-9][0-9]*$/.test(value)) {
        fail("--show-styles requires an integer greater than 0");
    }
}

async function main() {
    const options = parseArgs(process.argv.slice(2));

    if (options.listStyles) {
        const styles = await listStylesFromApi();
        process.stdout.write(`${styles.join("\n")}\n`);
        return;
    }

    if (options.searchStyle) {
        const styles = await listStylesFromApi();
        const matches = styles.filter((item) => item.toLowerCase().includes(options.searchStyle.toLowerCase()));
        if (matches.length > 0) {
            process.stdout.write(`${matches.join("\n")}\n`);
        }
        return;
    }

    if (options.showStyles) {
        validateShowStyles(options.showStyles);
        const styles = await listStylesFromApi();
        process.stdout.write(`${styles.slice(0, Number.parseInt(options.showStyles, 10)).join("\n")}\n`);
        return;
    }

    if (options.dois.length === 0 && !process.stdin.isTTY) {
        const stdinText = await readStdin();
        options.dois.push(...splitNonEmptyLines(stdinText));
    }

    const finalDois = options.dois.map(trim).filter(Boolean);
    if (finalDois.length === 0) {
        fail("No DOI provided. Pass one or more DOIs, or pipe DOI lines on stdin.");
    }

    if (options.outDir) {
        await fs.promises.mkdir(options.outDir, { recursive: true });
    }

    const payloads = [];
    for (let index = 0; index < finalDois.length; index += 1) {
        const doi = finalDois[index];
        const request = getRequestConfig(options.format, doi, options.style, options.locale);
        let content;
        try {
            content = await fetchOne(request.url, request.acceptHeader);
        } catch (error) {
            if (options.format === "text") {
                await maybeExplainStyleFailure(options.style, error);
            }
            throw error;
        }

        if (options.outDir) {
            const outputFile = path.join(
                options.outDir,
                `${sanitizeFilename(doi)}.${fileExtensionForFormat(options.format)}`,
            );
            await fs.promises.writeFile(outputFile, content, "utf8");
        } else {
            payloads.push(content);
        }
    }

    if (!options.outDir) {
        if (options.format === "json" || options.format === "csljson") {
            if (payloads.length === 1) {
                process.stdout.write(payloads[0]);
            } else {
                const parsed = payloads.map((item) => JSON.parse(item));
                process.stdout.write(`${JSON.stringify(parsed, null, 2)}\n`);
            }
            return;
        }

        payloads.forEach((item, index) => {
            process.stdout.write(item);
            if (index < payloads.length - 1) {
                process.stdout.write(options.format === "text" ? "\n" : "\n\n");
            }
        });
        return;
    }

    if (finalDois.length === 1) {
        console.error(`Saved 1 file to ${options.outDir}`);
    } else {
        console.error(`Saved ${finalDois.length} files to ${options.outDir}`);
    }
}

main().catch((error) => {
    console.error(error.message);
    process.exit(1);
});
